# ============================================
# TRADE INFINITY BOT — ENVIRONMENT VARIABLES
# ============================================
# Fill in your actual values and rename this file to .env
# NEVER share these values publicly!

# 1. Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 2. Supabase (from supabase.com dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_anon_public_key_here

# 3. Port (Railway/Render will set this automatically)
PORT=3000
